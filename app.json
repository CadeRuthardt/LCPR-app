{
  "expo": {
    "name": "Le Chateau 2.0",
    "slug": "LCPR-app",
    "scheme": "lcpr",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.partner-auto-5023.lcpr",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lechateaupetresort.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#fafaf0",
          "resizeMode": "contain",
          "imageWidth": 220
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bfa48ea5-381c-4841-9294-22c3334808f8"
      }
    }
  }
}
